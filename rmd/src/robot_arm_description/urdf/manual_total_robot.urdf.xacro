<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="manual_total_robot">
  <xacro:arg name="ifname" default="can0"/>
  <xacro:arg name="shoulder_actuator_id" default="4"/>
  <xacro:arg name="elbow_actuator_id" default="5"/>
  <xacro:arg name="wrist_actuator_id" default="6"/>
  <xacro:arg name="timeout" default="0"/>
  <xacro:arg name="max_velocity" default="30.0"/>
  <xacro:arg name="dxl_port_name" default="/dev/ttyUSB0"/>
  <xacro:arg name="dxl_baud_rate" default="1000000"/>

  <link name="base_link"/>
  <link name="base_yaw_link"/>
  <joint name="base_yaw_joint" type="revolute">
    <parent link="base_link"/><child link="base_yaw_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/><axis xyz="0 0 1"/>
    <limit lower="${-80.0*pi/180.0}" upper="${80.0*pi/180.0}" effort="1.0" velocity="4.8"/>
  </joint>
  <link name="shoulder_link"/>
  <joint name="shoulder_joint" type="revolute">
    <parent link="base_yaw_link"/><child link="shoulder_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-3.14159" upper="3.14159" effort="50.0" velocity="1.0"/>
  </joint>
  <link name="elbow_link"/>
  <joint name="elbow_joint" type="revolute">
    <parent link="shoulder_link"/><child link="elbow_link"/>
    <origin xyz="0.30 0 0" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-3.14159" upper="3.14159" effort="40.0" velocity="1.0"/>
  </joint>
  <link name="wrist_link"/>
  <joint name="wrist_joint" type="revolute">
    <parent link="elbow_link"/><child link="wrist_link"/>
    <origin xyz="0.25 0 0" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-3.14159" upper="3.14159" effort="25.0" velocity="1.0"/>
  </joint>
  <link name="gripper_link"/>
  <joint name="gripper_joint" type="revolute">
    <parent link="wrist_link"/><child link="gripper_link"/>
    <origin xyz="0.15 0 0" rpy="0 0 0"/><axis xyz="1 0 0"/>
    <limit lower="${-170.0*pi/180.0}" upper="${169.0*pi/180.0}" effort="1.0" velocity="4.8"/>
  </joint>

  <xacro:macro name="rmd_actuator" params="name joint_name actuator_id">
    <ros2_control name="${name}" type="actuator">
      <hardware>
        <plugin>myactuator_rmd_hardware/MyActuatorRmdHardwareInterface</plugin>
        <param name="ifname">$(arg ifname)</param><param name="actuator_id">${actuator_id}</param>
        <param name="torque_constant">1.0</param><param name="max_velocity">$(arg max_velocity)</param>
        <param name="velocity_alpha">0.1</param><param name="effort_alpha">0.1</param>
        <param name="timeout">$(arg timeout)</param>
      </hardware>
      <joint name="${joint_name}">
        <command_interface name="position"/><command_interface name="velocity"/><command_interface name="effort"/>
        <state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/>
      </joint>
    </ros2_control>
  </xacro:macro>
  <xacro:rmd_actuator name="shoulder_rmd" joint_name="shoulder_joint" actuator_id="$(arg shoulder_actuator_id)"/>
  <xacro:rmd_actuator name="elbow_rmd" joint_name="elbow_joint" actuator_id="$(arg elbow_actuator_id)"/>
  <!-- wrist 하드웨어 세팅 전까지 CAN 액추에이터 등록을 비활성화합니다.
  활성화할 때 아래 항목과 controller/manual node의 wrist 항목을 같은 배열 위치에 함께 추가해야 합니다.
  <xacro:rmd_actuator name="wrist_rmd" joint_name="wrist_joint" actuator_id="$(arg wrist_actuator_id)"/>
  -->

  <ros2_control name="dynamixel_system" type="system">
    <hardware>
      <plugin>dynamixel_hardware_interface/DynamixelHardware</plugin>
      <param name="port_name">$(arg dxl_port_name)</param><param name="baud_rate">$(arg dxl_baud_rate)</param>
      <param name="dynamixel_model_folder">/param/dxl_model</param>
      <param name="number_of_joints">2</param><param name="number_of_transmissions">2</param>
      <param name="disable_torque_at_init">true</param><param name="error_timeout_ms">1000</param>
      <param name="transmission_to_joint_matrix">1,0,0,1</param>
      <param name="joint_to_transmission_matrix">1,0,0,1</param>
      <param name="dynamixel_state_pub_msg_name">dynamixel_hardware_interface/dxl_state</param>
      <param name="get_dynamixel_data_srv_name">dynamixel_hardware_interface/get_dxl_data</param>
      <param name="set_dynamixel_data_srv_name">dynamixel_hardware_interface/set_dxl_data</param>
      <param name="reboot_dxl_srv_name">dynamixel_hardware_interface/reboot_dxl</param>
      <param name="set_dxl_torque_srv_name">dynamixel_hardware_interface/set_dxl_torque</param>
    </hardware>
    <joint name="gripper_joint"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/></joint>
    <joint name="base_yaw_joint"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/></joint>
    <gpio name="dxl1"><param name="type">dxl</param><param name="ID">4</param><command_interface name="Goal Position"/><state_interface name="Present Position"/><state_interface name="Present Velocity"/><state_interface name="Present Current"/><param name="Return Delay Time">0</param></gpio>
    <gpio name="dxl2"><param name="type">dxl</param><param name="ID">0</param><command_interface name="Goal Position"/><state_interface name="Present Position"/><state_interface name="Present Velocity"/><state_interface name="Present Current"/><param name="Return Delay Time">0</param></gpio>
  </ros2_control>
</robot>

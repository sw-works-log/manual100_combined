<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="manual_total_robot">
  <xacro:arg name="ifname" default="can0"/>
  <xacro:arg name="shoulder_actuator_id" default="4"/>
  <xacro:arg name="elbow_actuator_id" default="5"/>
  <xacro:arg name="wrist_actuator_id" default="6"/>
  <xacro:arg name="timeout" default="0"/>
  <!-- Conservative bringup limit in degrees per second. -->
  <xacro:arg name="max_velocity" default="5.0"/>
  <xacro:arg name="dxl_port_name" default="/dev/ttyUSB0"/>
  <xacro:arg name="dxl_baud_rate" default="1000000"/>

  <!--
    Geometry/joint origins come from the confirmed army_manipulator model.
    Joint names follow the army_manipulator controller and MoveIt contract.
    The angle limits below are provisional
    design values, not calibrated hardware safety limits.
  -->
  <xacro:property name="sh_off" value="0.1616"/>
  <xacro:property name="L1" value="0.180"/>
  <xacro:property name="L2" value="0.220"/>
  <xacro:property name="off_shoulder" value="-0.0377"/>
  <xacro:property name="off_elbow" value="0.0188"/>
  <xacro:property name="off_wrist" value="-0.0313"/>
  <xacro:property name="off_gripper" value="0.038"/>

  <material name="cfrp"><color rgba="0.15 0.15 0.15 1.0"/></material>
  <material name="petg_grey"><color rgba="0.55 0.55 0.55 1.0"/></material>
  <material name="motor_dark"><color rgba="0.25 0.25 0.25 1.0"/></material>
  <material name="tcp_red"><color rgba="1.0 0.1 0.1 1.0"/></material>

  <link name="base_link">
    <visual><geometry><box size="0.100 0.100 0.008"/></geometry><material name="petg_grey"/></visual>
    <collision><geometry><box size="0.100 0.100 0.008"/></geometry></collision>
    <inertial>
      <mass value="0.3"/><origin xyz="0 0 0"/>
      <inertia ixx="2.5e-4" ixy="0" ixz="0" iyy="2.5e-4" iyz="0" izz="5.0e-4"/>
    </inertial>
  </link>
  <link name="base_yaw_link">
    <visual><geometry><cylinder radius="0.028" length="0.055"/></geometry><material name="motor_dark"/></visual>
    <collision><geometry><cylinder radius="0.028" length="0.055"/></geometry></collision>
    <inertial>
      <mass value="0.202"/><origin xyz="0 0 0"/>
      <inertia ixx="1.3e-4" ixy="0" ixz="0" iyy="1.3e-4" iyz="0" izz="8.0e-5"/>
    </inertial>
  </link>
  <joint name="base_rotate_joint" type="revolute">
    <parent link="base_link"/><child link="base_yaw_link"/>
    <origin xyz="0 0 ${sh_off}" rpy="0 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="3.1" velocity="2.618"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>
  <link name="shoulder_link">
    <visual>
      <origin xyz="${L1/2} 0 0" rpy="0 1.5708 0"/>
      <geometry><box size="0.020 0.020 ${L1}"/></geometry><material name="cfrp"/>
    </visual>
    <collision>
      <origin xyz="${L1/2} 0 0" rpy="0 0 0"/>
      <geometry><box size="${L1} 0.022 0.022"/></geometry>
    </collision>
    <inertial>
      <mass value="0.08"/><origin xyz="${L1/2} 0 0"/>
      <inertia ixx="6.0e-6" ixy="0" ixz="0" iyy="2.2e-4" iyz="0" izz="2.2e-4"/>
    </inertial>
  </link>
  <joint name="shoulder_lift_joint" type="revolute">
    <parent link="base_yaw_link"/><child link="shoulder_link"/>
    <origin xyz="0 0 ${off_shoulder}" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="0.0" upper="2.0944" effort="120.0" velocity="1.047"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>
  <link name="elbow_link">
    <visual>
      <origin xyz="${L2/2} 0 0" rpy="0 1.5708 0"/>
      <geometry><box size="0.020 0.020 ${L2}"/></geometry><material name="cfrp"/>
    </visual>
    <collision>
      <origin xyz="${L2/2} 0 0" rpy="0 0 0"/>
      <geometry><box size="${L2} 0.022 0.022"/></geometry>
    </collision>
    <inertial>
      <mass value="0.10"/><origin xyz="${L2/2} 0 0"/>
      <inertia ixx="7.3e-6" ixy="0" ixz="0" iyy="4.0e-4" iyz="0" izz="4.0e-4"/>
    </inertial>
  </link>
  <joint name="elbow_joint" type="revolute">
    <parent link="shoulder_link"/><child link="elbow_link"/>
    <origin xyz="${L1} 0 ${off_elbow}" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="0.3491" effort="60.0" velocity="1.571"/>
    <dynamics damping="0.5" friction="0.05"/>
  </joint>
  <link name="wrist_link">
    <visual><geometry><cylinder radius="0.022" length="0.038"/></geometry><material name="petg_grey"/></visual>
    <collision><geometry><cylinder radius="0.022" length="0.038"/></geometry></collision>
    <inertial>
      <mass value="0.09"/><origin xyz="0 0 0"/>
      <inertia ixx="5.0e-5" ixy="0" ixz="0" iyy="5.0e-5" iyz="0" izz="3.0e-5"/>
    </inertial>
  </link>
  <joint name="wrist_joint" type="revolute">
    <parent link="elbow_link"/><child link="wrist_link"/>
    <origin xyz="${L2} 0 ${off_wrist}" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-2.0944" upper="2.0944" effort="36.0" velocity="2.618"/>
    <dynamics damping="0.2" friction="0.02"/>
  </joint>
  <link name="gripper_link">
    <visual>
      <origin xyz="0 0 0.110" rpy="0 0 0"/>
      <geometry><box size="0.040 0.095 0.182"/></geometry><material name="petg_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.110" rpy="0 0 0"/>
      <geometry><box size="0.040 0.095 0.182"/></geometry>
    </collision>
    <inertial>
      <mass value="0.15"/><origin xyz="0 0 0.110"/>
      <inertia ixx="5.0e-4" ixy="0" ixz="0" iyy="5.0e-4" iyz="0" izz="1.0e-4"/>
    </inertial>
  </link>
  <joint name="gripper_joint" type="revolute">
    <parent link="wrist_link"/><child link="gripper_link"/>
    <origin xyz="0 0 ${off_gripper}" rpy="0 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-2.3562" upper="2.3562" effort="8.4" velocity="3.665"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>

  <link name="tcp_link">
    <visual><geometry><sphere radius="0.005"/></geometry><material name="tcp_red"/></visual>
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/>
    </inertial>
  </link>
  <joint name="tcp_joint" type="fixed">
    <parent link="gripper_link"/><child link="tcp_link"/>
    <origin xyz="0 0 0.182" rpy="0 0 0"/>
  </joint>

  <xacro:macro name="rmd_actuator" params="name joint_name actuator_id">
    <ros2_control name="${name}" type="actuator">
      <hardware>
        <plugin>rmd_hardware_interface/MyActuatorRmdHardwareInterface</plugin>
        <param name="ifname">$(arg ifname)</param><param name="actuator_id">${actuator_id}</param>
        <param name="torque_constant">1.0</param><param name="max_velocity">$(arg max_velocity)</param>
        <param name="velocity_alpha">0.1</param><param name="effort_alpha">0.1</param>
        <param name="timeout">$(arg timeout)</param>
      </hardware>
      <joint name="${joint_name}">
        <command_interface name="position"/><command_interface name="velocity"/><command_interface name="effort"/>
        <state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/>
      </joint>
    </ros2_control>
  </xacro:macro>
  <xacro:rmd_actuator name="shoulder_rmd" joint_name="shoulder_lift_joint" actuator_id="$(arg shoulder_actuator_id)"/>
  <xacro:rmd_actuator name="elbow_rmd" joint_name="elbow_joint" actuator_id="$(arg elbow_actuator_id)"/>
  <xacro:rmd_actuator name="wrist_rmd" joint_name="wrist_joint" actuator_id="$(arg wrist_actuator_id)"/>

  <!-- RMD CAN ID 4, 5, 6 구동 중에는 Dynamixel을 초기화하지 않습니다.
  다시 사용할 때 이 블록과 manual_total_controllers.yaml 및
  manual_total_position_node.py의 gripper/base_yaw 항목을 함께 활성화해야 합니다.
  <ros2_control name="dynamixel_system" type="system">
    <hardware>
      <plugin>dynamixel_hardware_interface/DynamixelHardware</plugin>
      <param name="port_name">$(arg dxl_port_name)</param><param name="baud_rate">$(arg dxl_baud_rate)</param>
      <param name="dynamixel_model_folder">/param/dxl_model</param>
      <param name="number_of_joints">2</param><param name="number_of_transmissions">2</param>
      <param name="disable_torque_at_init">true</param><param name="error_timeout_ms">1000</param>
      <param name="transmission_to_joint_matrix">1,0,0,1</param>
      <param name="joint_to_transmission_matrix">1,0,0,1</param>
      <param name="dynamixel_state_pub_msg_name">dynamixel_hardware_interface/dxl_state</param>
      <param name="get_dynamixel_data_srv_name">dynamixel_hardware_interface/get_dxl_data</param>
      <param name="set_dynamixel_data_srv_name">dynamixel_hardware_interface/set_dxl_data</param>
      <param name="reboot_dxl_srv_name">dynamixel_hardware_interface/reboot_dxl</param>
      <param name="set_dxl_torque_srv_name">dynamixel_hardware_interface/set_dxl_torque</param>
    </hardware>
    <joint name="gripper_joint"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/></joint>
    <joint name="base_rotate_joint"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/></joint>
    <gpio name="dxl1"><param name="type">dxl</param><param name="ID">4</param><command_interface name="Goal Position"/><state_interface name="Present Position"/><state_interface name="Present Velocity"/><state_interface name="Present Current"/><param name="Return Delay Time">0</param></gpio>
    <gpio name="dxl2"><param name="type">dxl</param><param name="ID">0</param><command_interface name="Goal Position"/><state_interface name="Present Position"/><state_interface name="Present Velocity"/><state_interface name="Present Current"/><param name="Return Delay Time">0</param></gpio>
  </ros2_control>
  -->
</robot>
